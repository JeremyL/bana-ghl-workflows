# Sensitive data — never commit CSV files (contain PII)
*.csv

# Environment variables — API tokens
.env

# Temp test files
*.temp

# Local scripts & exports (ad-hoc data-processing, API outputs, checkpoints)
scripts/

# n8n workflow exports (contain API keys / location IDs)
n8n/*.json

# VAPI agent configs (may contain API keys / sensitive config)
vapi/

# FUB import scripts & data (one-time migration, contains PII + API calls)
new-leads/import/

# Claude Code config (contains approved commands with embedded tokens)
.claude/
